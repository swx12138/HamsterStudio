<Window x:Class="HamsterStudio.Gallery.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:local="clr-namespace:HamsterStudio.Gallery"
        xmlns:localv="clr-namespace:HamsterStudio.Gallery.Views"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        Title="{Binding ViewModel.DisplayName}"
        Width="1600"
        Height="1200"
        Topmost="{Binding Topmost}"
        WindowStartupLocation="CenterScreen"
        mc:Ignorable="d">
    <Window.DataContext>
        <local:MainWindowModel />
    </Window.DataContext>
    <localv:GalleryView DataContext="{Binding ViewModel}" />
</Window>
