<UserControl x:Class="HamsterStudio.Gallery.Views.GalleryView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:hfs="clr-namespace:HamsterStudio.Barefeet.FileSystem;assembly=HamsterStudio.Barefeet"
             xmlns:local="clr-namespace:HamsterStudio.Gallery.Views"
             xmlns:localdts="clr-namespace:HamsterStudio.Gallery.DataTemplateSelectors"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             d:DesignHeight="450"
             d:DesignWidth="800"
             mc:Ignorable="d">
    <DockPanel>
        <DockPanel.Resources>
            <HierarchicalDataTemplate x:Key="GalleryFolderTemplate" DataType="localm:GalleryFolderModel" ItemsSource="{Binding Folders}">
                <StackPanel Orientation="Horizontal">
                    <StackPanel.ContextMenu>
                        <ContextMenu>
                            <MenuItem Command="{Binding OpenFolderCommand}" Header="打开文件夹" />
                        </ContextMenu>
                    </StackPanel.ContextMenu>
                    <TextBlock VerticalAlignment="Center" Foreground="ForestGreen" Text="{Binding DirInfo.Name}" />
                    <TextBlock Text=" - " />
                    <TextBlock VerticalAlignment="Center" Foreground="Firebrick" Text="{Binding Files.Count}" />
                </StackPanel>
            </HierarchicalDataTemplate>
        </DockPanel.Resources>
        <Border>
            <DockPanel>
                <Button Margin="2"
                        HorizontalAlignment="Stretch"
                        Command="{Binding LoadFolderCommand}"
                        Content="添加..."
                        DockPanel.Dock="Top" />
                <Button Margin="2"
                        HorizontalAlignment="Stretch"
                        Command="{Binding RemoveFolderCommand}"
                        Content="移除"
                        DockPanel.Dock="Top" />
                <TreeView MinWidth="128"
                          DockPanel.Dock="Left"
                          ItemTemplate="{StaticResource GalleryFolderTemplate}"
                          ItemsSource="{Binding GalleryFolders.Folders}"
                          SelectedItemChanged="TreeView_SelectedItemChanged" />
            </DockPanel>

        </Border>
        <Border BorderBrush="Red" BorderThickness="1" CornerRadius="5">
            <Border.ContextMenu>
                <ContextMenu>
                    <MenuItem Header="缩略图模式" IsCheckable="True" IsChecked="{Binding IsThumbnailView}" />
                </ContextMenu>
            </Border.ContextMenu>
            <local:ThumbnailModeView DataContext="{Binding ThumbnailModeViewModel}" />
        </Border>
    </DockPanel>
</UserControl>
