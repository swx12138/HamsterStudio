<UserControl x:Class="HamsterStudio.Gallery.Views.GalleryView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:hc="https://handyorg.github.io/handycontrol"
             xmlns:hfs="clr-namespace:HamsterStudio.Barefeet.FileSystem;assembly=HamsterStudio.Barefeet"
             xmlns:local="clr-namespace:HamsterStudio.Gallery.Views"
             xmlns:localdts="clr-namespace:HamsterStudio.Gallery.DataTemplateSelectors"
             xmlns:localvm="clr-namespace:HamsterStudio.Gallery.ViewModels"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             d:DesignHeight="450"
             d:DesignWidth="800"
             mc:Ignorable="d">
    <DockPanel>
        <DockPanel.Resources>
            <HierarchicalDataTemplate x:Key="GalleryFolderTemplate" DataType="localm:GalleryFolderModel" ItemsSource="{Binding Folders}">
                <StackPanel Orientation="Horizontal">
                    <StackPanel.ContextMenu>
                        <ContextMenu>
                            <MenuItem Command="{Binding OpenFolderCommand}" Header="打开文件夹" />
                        </ContextMenu>
                    </StackPanel.ContextMenu>
                    <TextBlock VerticalAlignment="Center" Foreground="ForestGreen" Text="{Binding DirInfo.Name}" />
                    <TextBlock Text=" - " />
                    <TextBlock VerticalAlignment="Center" Foreground="Firebrick" Text="{Binding Files.Count}" />
                </StackPanel>
            </HierarchicalDataTemplate>
            <localdts:ViewModeDataTemplateSelector x:Key="ViewModeDataTemplateSelector">
                <localdts:ViewModeDataTemplateSelector.ThumbnailView>
                    <DataTemplate DataType="localvm:ThumbnailModeViewModel">
                        <local:ThumbnailModeView />
                    </DataTemplate>
                </localdts:ViewModeDataTemplateSelector.ThumbnailView>
                <localdts:ViewModeDataTemplateSelector.LargeImageView>
                    <DataTemplate DataType="localvm:LargeImageViewModel">
                        <DockPanel>
                            <!--<hc:PropertyGrid SelectedObject="{Binding}" />-->
                            <hc:ImageViewer ImageSource="{Binding CurrentImage}" />
                        </DockPanel>
                    </DataTemplate>
                </localdts:ViewModeDataTemplateSelector.LargeImageView>
                <localdts:ViewModeDataTemplateSelector.DefaultView>
                    <DataTemplate DataType="localvm:LargeImageViewModel">
                        <DockPanel>
                            <hc:PropertyGrid SelectedObject="{Binding}" />
                        </DockPanel>
                    </DataTemplate>
                </localdts:ViewModeDataTemplateSelector.DefaultView>
            </localdts:ViewModeDataTemplateSelector>
        </DockPanel.Resources>
        <Border DockPanel.Dock="Left">
            <DockPanel>
                <Button Margin="2"
                        HorizontalAlignment="Stretch"
                        Command="{Binding LoadFolderCommand}"
                        Content="添加..."
                        DockPanel.Dock="Top" />
                <Button Margin="2"
                        HorizontalAlignment="Stretch"
                        Command="{Binding RemoveFolderCommand}"
                        Content="移除"
                        DockPanel.Dock="Top" />
                <CheckBox Content="缩略图模式" DockPanel.Dock="Top" IsChecked="{Binding IsThumbnailView}" />
                <TreeView MinWidth="128"
                          DockPanel.Dock="Left"
                          ItemTemplate="{StaticResource GalleryFolderTemplate}"
                          ItemsSource="{Binding GalleryFolders.Folders}"
                          SelectedItemChanged="TreeView_SelectedItemChanged" />
            </DockPanel>
        </Border>
        <Border BorderBrush="Red" BorderThickness="1" CornerRadius="5">
            <ContentPresenter Content="{Binding ContentDataContext}" ContentTemplateSelector="{StaticResource ViewModeDataTemplateSelector}" />
            <!--<hc:PropertyGrid SelectedObject="{Binding}" />-->
        </Border>
    </DockPanel>
</UserControl>
